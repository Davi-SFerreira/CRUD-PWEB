<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <title>Editar Produto</title>
  <style>
    body { font-family: Arial, sans-serif; display: flex; justify-content: center; align-items: center; height: 100vh; background: #f0f0f0; }
    .box { background: white; padding: 2rem; border-radius: 8px; width: 300px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); }
    h2 { margin-bottom: 1rem; }
    input { width: 100%; padding: 8px; margin-bottom: 1rem; box-sizing: border-box; border: 1px solid #ccc; border-radius: 4px; }
    button { width: 100%; padding: 10px; background: #2196F3; color: white; border: none; border-radius: 4px; cursor: pointer; }
    a { display: block; text-align: center; margin-top: 1rem; color: #666; }
  </style>
</head>
<body>
  <div class="box">
    <h2>Editar Produto</h2>

    <form action="/produtos/editar/<%= produto.id %>" method="POST">
      <!-- value="..." já preenche com os dados atuais do produto -->
      <input type="text" name="nome" value="<%= produto.nome %>" required />
      <input type="number" name="preco" value="<%= produto.preco %>" step="0.01" required />
      <button type="submit">Salvar</button>
    </form>

    <a href="/">← Voltar</a>
  </div>
</body>
</html>