<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <title>Login</title>
  <style>
    body { font-family: Arial, sans-serif; display: flex; justify-content: center; align-items: center; height: 100vh; margin: 0; background: #f0f0f0; }
    .box { background: white; padding: 2rem; border-radius: 8px; width: 300px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); }
    h2 { margin-bottom: 1rem; }
    input { width: 100%; padding: 8px; margin-bottom: 1rem; box-sizing: border-box; border: 1px solid #ccc; border-radius: 4px; }
    button { width: 100%; padding: 10px; background: #4CAF50; color: white; border: none; border-radius: 4px; cursor: pointer; }
    .erro { color: red; margin-bottom: 1rem; }
  </style>
</head>
<body>
  <div class="box">
    <h2>Login</h2>

    <!-- Mostra erro se usuário/senha estiver errado -->
    <% if (erro) { %>
      <p class="erro"><%= erro %></p>
    <% } %>

    <form action="/login" method="POST">
      <input type="text" name="usuario" placeholder="Usuário" required />
      <input type="password" name="senha" placeholder="Senha" required />
      <button type="submit">Entrar</button>
    </form>
  </div>
</body>
</html>